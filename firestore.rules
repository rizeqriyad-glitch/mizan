rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /completed/{completedId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /prayers/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /stats/{statId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /sections/{sectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /notes/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /dhikr/{dhikrId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /adhkar/{adhkarId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /dayPrograms/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /weeklyItems/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /weeklySchedule/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /goals/{goalId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /gamification/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /prayerScheduleItems/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /customScheduleItems/{itemId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /savedSchedules/{scheduleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
