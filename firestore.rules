rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Tasks subcollection
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Completed tasks subcollection
      match /completed/{completedId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Prayer records subcollection
      match /prayers/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Stats subcollection
      match /stats/{statId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Custom sections subcollection
      match /sections/{sectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
