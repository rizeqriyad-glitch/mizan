# ============================================================
# MIZAN — Environment Variables (example)
# Copy to .env.local (dev) or set these in Railway → Variables (prod).
# Real .env / .env.local are gitignored and never committed.
# ============================================================
#
# Stack note: this is a Vite + React SPA. Vite exposes only vars prefixed
# with VITE_ and INLINES them at BUILD time (not runtime). So on Railway these
# must be present when `npm run build` runs — add them in the Variables tab,
# then trigger/redeploy so the build picks them up.
#
# Firebase web config — these are PUBLIC client identifiers, not secrets
# (Firebase security is enforced by Firestore rules + Auth, not by hiding them).
# All are OPTIONAL: src/firebase.js falls back to the project defaults if unset.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set automatically by Railway / the build; listed for completeness.
NODE_ENV=production

# NOTE: This app has NO server database and NO NextAuth, so there is
# intentionally NO DATABASE_URL / NEXTAUTH_SECRET / NEXTAUTH_URL.
# Auth + data are handled client-side by Firebase (above).
